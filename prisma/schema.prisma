generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SongRequest {
  id           String        @id
  service      SongService
  url          String
  title        String?
  status       RequestStatus @default(PENDING)
  play_time    BigInt
  channel_id   String
  request_from RequestFrom
  requested_by String
  requested_at DateTime      @default(now())

  @@unique([channel_id, url])
  @@index([channel_id])
  @@index([requested_by])
}

enum SongService {
  YOUTUBE
  SOUNDCLOUD
}

enum RequestStatus {
  PENDING
  PLAYING
}

enum RequestFrom {
  CHAT
  WEBSITE
}

model Channel {
  channelId     String        @id
  name          String
  imageUrl      String?
  followerCount Int           @default(0)
  status        ChannelStatus @default(ACTIVE)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  token         ChzzkToken?
}

model ChzzkToken {
  id           String   @id @default(cuid())
  channelId    String   @unique
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  channel      Channel  @relation(fields: [channelId], references: [channelId], onDelete: Cascade)
}

enum ChannelStatus {
  ACTIVE
  NEEDS_REAUTH
}
